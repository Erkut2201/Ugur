{
  "name": "ac-premium-bau",
  "version": "1.0.0",
  "description": "Büro-Verwaltung für Konzept Terrasse BW",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n SERVER,CLIENT -c cyan,green \"tsx watch server/index.ts\" \"vite\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "dev:public": "vite --mode public",
    "dev:portal": "vite --mode portal",
    "build": "npm run build:portal && npm run build:server",
    "build:client": "vite build",
    "build:public": "vite build --mode public",
    "build:portal": "vite build --mode portal",
    "build:server": "esbuild server/index.ts --bundle --platform=node --target=node20 --format=esm --packages=external --outfile=dist/server.js",
    "start": "node dist/server.js",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "generate:images": "node scripts/generate-images.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.556.0",
    "@aws-sdk/s3-request-presigner": "^3.556.0",
    "@tanstack/react-query": "^5.37.1",
    "bcryptjs": "^2.4.3",
    "connect-pg-simple": "^9.0.1",
    "csrf-csrf": "^3.2.2",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.39.0",
    "express": "^4.19.2",
    "express-session": "^1.18.0",
    "helmet": "^8.1.0",
    "jimp": "^1.6.1",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.13",
    "pg": "^8.11.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.0",
    "react-hook-form": "^7.51.4",
    "resend": "^6.12.2",
    "sharp": "^0.35.3",
    "wouter": "^3.3.0",
    "zod": "^3.23.4"
  },
  "devDependencies": {
    "@fontsource/lato": "^5.2.7",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.5",
    "@types/nodemailer": "^6.4.14",
    "@types/pg": "^8.11.5",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "better-sqlite3": "^12.10.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.30.0",
    "esbuild": "^0.21.1",
    "mupdf": "^1.27.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "tsx": "^4.9.3",
    "typescript": "^5.4.5",
    "vite": "^5.2.10",
    "xlsx": "^0.18.5"
  },
  "optionalDependencies": {
    "@types/react": "^18.3.1"
  }
}
