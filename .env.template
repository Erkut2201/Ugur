# ── Server / Domains ──────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
PUBLIC_URL=https://konzept-terrasse.de
INVOICE_URL=https://rechnungen.konzept-terrasse.de
COOKIE_DOMAIN=rechnungen.konzept-terrasse.de
ALLOWED_ORIGINS=https://konzept-terrasse.de,https://www.konzept-terrasse.de,https://rechnungen.konzept-terrasse.de
PUBLIC_INQUIRY_EMAIL=

# ── Firmendaten (werden in PDFs und E-Mails verwendet — KEIN hardcoded Text) ──
COMPANY_NAME=
COMPANY_STREET=
COMPANY_ZIP=
COMPANY_CITY=
COMPANY_PHONE=
COMPANY_MOBILE=
COMPANY_EMAIL=
COMPANY_WEBSITE=
COMPANY_OFFICE_STREET=
COMPANY_OFFICE_ZIP=
COMPANY_OFFICE_CITY=

# ── Bankverbindung (für Rechnungs-PDFs) ───────────────────────────────────────
COMPANY_BANK_NAME=
COMPANY_IBAN=
COMPANY_BIC=

# ── Steuer (reguläres Unternehmen — MwSt. wird berechnet und ausgewiesen) ─────
COMPANY_TAX_ID=
COMPANY_VAT_ID=
COMPANY_FINANZAMT=
DEFAULT_VAT_RATE=19

# ── Ansprechpartner / Lieferzeit ──────────────────────────────────────────────
COMPANY_CONTACT_PERSON=
DEFAULT_DELIVERY_TIME=

# ── Dokumenten-Nummernpräfixe ─────────────────────────────────────────────────
QUOTE_PREFIX=ANG
INVOICE_PREFIX=RNG
PROTOCOL_PREFIX=ABN

# ── Admin-Account (wird beim ersten Start automatisch angelegt) ───────────────
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ── Session ───────────────────────────────────────────────────────────────────
# Generieren: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
SESSION_SECRET=

# ── PostgreSQL (Produktion — Render/Neon) ─────────────────────────────────────
POSTGRES_URL=
PG_HOST=
PG_PORT=5432
PG_USER=
PG_PASSWORD=
PG_DATABASE=
PG_SSL=true

# ── SQLite-Fallback (lokal ohne Postgres) ─────────────────────────────────────
SQLITE_PATH=./data/local.db

# ── E-Mail (Brevo / SMTP) ─────────────────────────────────────────────────────
BREVO_API_KEY=
BREVO_FROM=
SMTP_HOST=smtp.ionos.de
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ── S3 Object Storage (Produktion) ────────────────────────────────────────────
S3_BUCKET=
S3_REGION=eu-central-1
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ── PDF-Bilder ────────────────────────────────────────────────────────────────
COMPANY_HEADER_IMAGE=attachments/header.jpg

# ── Lokaler Dateispeicher (Fallback wenn kein S3) ─────────────────────────────
LOCAL_STORAGE_PATH=./data/pdfs
